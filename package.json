{
  "name": "vipershell",
  "version": "0.0.2",
  "description": "Your machine, anywhere — View and interact with your tmux sessions from any browser",
  "type": "module",
  "bin": {
    "vipershell": "./dist/index.js"
  },
  "files": [
    "dist",
    "ui/dist"
  ],
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:ui": "cd ui && npm run build",
    "dev": "bash dev.sh",
    "start": "node dist/index.js",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@vectorize-io/hindsight-client": "^0.4.20",
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "node-pty": "^1.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "systeminformation": "^5.22.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  }
}
